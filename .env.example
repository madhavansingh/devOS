# ════════════════════════════════════════════════════════════
# DevOS — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.
# ════════════════════════════════════════════════════════════

# ── NextAuth v5 ──────────────────────────────
# Generate a strong secret: npx auth secret
AUTH_SECRET=

# ── GitHub OAuth App ─────────────────────────
# Create at: https://github.com/settings/developers
# Callback URL: http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Supabase ─────────────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Redis ────────────────────────────────────
# Required for: rate limiting, caching, job queue
# Local: redis://localhost:6379
# Production: use Upstash, Redis Cloud, or AWS ElastiCache
REDIS_URL=redis://localhost:6379

# ── Ollama (optional) ────────────────────────
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5-coder
# OLLAMA_EMBED_MODEL=nomic-embed-text

# ── RAG Retrieval ────────────────────────────
# "vector" = pure vector similarity (stable, recommended)
# "hybrid" = vector + keyword search with RRF fusion
RETRIEVAL_MODE=vector
